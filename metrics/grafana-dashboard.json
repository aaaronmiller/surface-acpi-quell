{
  "title": "Surface ACPI Quell",
  "description": "ACPI interrupt storm status and history",
  "tags": ["acpi", "surface", "linux"],
  "timezone": "browser",
  "panels": [
    {
      "title": "Module Status",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}
        }
      },
      "targets": [{"expr": "surface_acpi_module_loaded", "legendFormat": ""}]
    },
    {
      "title": "IRQ 9 Rate (/sec)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [
            {"color": "green", "value": 0},
            {"color": "yellow", "value": 50},
            {"color": "red", "value": 500}
          ]}
        }
      },
      "targets": [{"expr": "surface_acpi_irq9_rate", "legendFormat": ""}]
    },
    {
      "title": "ACPI Errors/min",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [
            {"color": "green", "value": 0},
            {"color": "yellow", "value": 10},
            {"color": "red", "value": 100}
          ]}
        }
      },
      "targets": [{"expr": "surface_acpi_acpi_errors_1m", "legendFormat": ""}]
    },
    {
      "title": "IRQ 9 Count (cumulative)",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "surface_acpi_irq9_count", "legendFormat": "IRQ 9"}]
    },
    {
      "title": "System Uptime",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 12},
      "fieldConfig": {
        "defaults": {
          "unit": "seconds",
          "color": {"mode": "none"}
        }
      },
      "targets": [{"expr": "surface_acpi_uptime_seconds", "legendFormat": ""}]
    },
    {
      "title": "History Health %",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 12},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {"steps": [
            {"color": "red", "value": 0},
            {"color": "yellow", "value": 90},
            {"color": "green", "value": 99}
          ]}
        }
      },
      "targets": [{
        "expr": "100 * (1 - surface_acpi_history_problems / surface_acpi_history_entries)",
        "legendFormat": ""
      }]
    }
  ],
  "schemaVersion": 27,
  "version": 1
}
